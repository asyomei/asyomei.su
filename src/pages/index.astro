---
import { fetchActions } from '~/backend/actions'
import A from '~/components/A.astro'
import ActionList from '~/components/ActionList.astro'
import Section from '~/components/Section.astro'
import Table from '~/components/Table.astro'
import DefaultLayout from '~/layouts/DefaultLayout.astro'

const actions = await fetchActions()
---

<DefaultLayout>
  <Section>hey</Section>

  <Section>
    i'm <b>asyomei</b> <br />
    another person in this world <br />
    lazy stupid airhead
  </Section>

  <Section title="info">
    <Table>
      <span>name</span>
      <span>vadim (<A href="//my/nameAtJapanese">syomei</A>)</span>

      <span>email</span>
      <span>neko (at this domain)</span>

      <span>birthday</span>
      <span>feb 9</span>

      <span>languages</span>
      <span>ru, en</span>

      <span>fav color</span>
      <span>#7e77bb <div id="fav-color" /> (it's from my avatar :D)</span>

      <span>fav music</span>
      <span>metalcore, deathcore, post-hardcore</span>

      <span>fav band</span>
      <span><A href="//currents">Currents</A></span>

      <span>fav anime</span>
      <span><A href="//gochiusa">gochiusa</A></span>
    </Table>
  </Section>

  <Section title="links">
    <Table>
      <span>telegram</span>
      <span><A href="//my/telegram">@asyomei</A></span>

      <span>matrix</span>
      <span><A href="//my/matrix">@asyomei:matrix.org</A></span>

      <span>github</span>
      <span><A href="//my/github">asyomei</A></span>
    </Table>
  </Section>

  {actions.length > 0 && (
    <Section title="actions">
      <ActionList actions={actions} />
    </Section>
  )}

  <Section title="another (useless) links" class="leading-4.5">
    <p><A href="//ayaya10h">ayaya 10h</A> - why not</p>
    <p><A href="/neko.gif" target="_blank">/neko.gif</A> - animated avatar from anime acchi kocchi</p>
  </Section>
</DefaultLayout>

<style is:global>
  #fav-color {
    @apply inline-block w-2.5 h-2.5 border-d bg-[#7e77bb];
  }
</style>
