---
import { SEO } from 'astro-seo'
import A from '~/components/A.astro'
import Section from '~/components/Section.astro'
import DefaultLayout from '~/layouts/DefaultLayout.astro'
import { formatPostDate } from '~/utils/format-post-date'
import { importPosts } from '~/utils/import-posts'

export const prerender = true

export function getStaticPaths() {
  const posts = importPosts()
  return posts.map(({ default: Post, ...post }) => ({
    params: { lang: post.lang, id: post.id },
    props: { Post, ...post },
  }))
}

const { Post, lang, id, ...data } = Astro.props
const altLang = { ru: 'en', en: 'ru' }[lang]!
const altUrl = `/blog/${altLang}/${id}`
const altText = { ru: 'на русском', en: 'on english' }[altLang]
---

<DefaultLayout title={data.title} description={data.description} class="text-content leading-normal">
  <Section class="pb-4 border-b-d">
    <div class="pb-3">
      <h1 class="text-2xl text-primary">{data.title}</h1>
      <p class="text-secondary">{formatPostDate(data.created, lang)}</p>
    </div>

    <A href={altUrl}>{altText}</A>
  </Section>

  <Post />
</DefaultLayout>
